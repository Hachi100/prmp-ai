# Base de données PostgreSQL 16
DATABASE_URL=postgresql://prmp_user:password@localhost:5432/prmp_pro

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (embeddings RAG)
VOYAGE_API_KEY=pa-...

# Better-Auth
BETTER_AUTH_SECRET=your-secret-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# MinIO (stockage fichiers S3-compatible)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DAO=prmp-dao
MINIO_BUCKET_DOCS=prmp-documents

# Resend (email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@prmp.bj

# WhatsApp Business API
WHATSAPP_TOKEN=...
WHATSAPP_PHONE_ID=...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PRMP-Pro
